APP_ENV=development
APP_NAME=AI-HPS
APP_VERSION=1.0.0

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgresql:postgresql@localhost:5432/AIHPS

# ── Redis (via docker-compose or native) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── RabbitMQ (via docker-compose) ─────────────────────────────────────────────
RABBITMQ_URL=amqp://aihps:aihps_dev_pass@localhost:5672/

# ── Auth — generate a strong random secret for production ─────────────────────
SECRET_KEY=change-me-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES_STAFF=480
ACCESS_TOKEN_EXPIRE_MINUTES_ADMIN=240
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=30

# ── LLM provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# ── Groq API key (get yours free at https://console.groq.com) ─────────────────
# REQUIRED for AI summaries — without this the system returns raw procedure text.
# Paste your key below. It starts with gsk_
GROQ_API_KEY=

# Groq endpoints (do not change unless Groq changes their API structure)
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_ENDPOINT=https://api.groq.com/openai/v1/chat/completions

# ── Optional fallback LLM providers ───────────────────────────────────────────
GEMINI_API_KEY=

# ── LLM generation parameters ─────────────────────────────────────────────────
TEMPERATURE=0.2
MAX_TOKENS=650

# ── RAG retrieval parameters ──────────────────────────────────────────────────
RAG_TOP_K=5          # number of procedure chunks sent to the LLM
RAG_MIN_SIMILARITY=0.35  # minimum vector similarity score (0.0–1.0)

# ── Phase 1 departments ───────────────────────────────────────────────────────
PHASE1_DEPARTMENTS=Emergency,Blood Bank,ICU,Surgery,Maternity,Infection Control
