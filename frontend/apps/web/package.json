{
  "name": "aihps-web",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n staff,patient -c blue,green \"vite\" \"vite --config vite.patient.config.ts\"",
    "dev:staff": "vite",
    "dev:patient": "vite --config vite.patient.config.ts",
    "build": "tsc && vite build && vite build --config vite.patient.config.ts",
    "build:staff": "tsc && vite build",
    "build:patient": "tsc && vite build --config vite.patient.config.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@tanstack/react-query": "^5.60.0",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "react-router-dom": "^7.1.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
